#!/bin/sh
set -u

SELF_DIR=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
ROOT_DIR=$(CDPATH='' cd -- "${SELF_DIR}/.." && pwd)

. "${ROOT_DIR}/lib/common.sh"
. "${ROOT_DIR}/lib/config.sh"

VERSION=$(sed -n '1p' "${ROOT_DIR}/VERSION" 2>/dev/null)
CONFIG_FILE="${HOMELAB_DOCTOR_CONFIG:-${ROOT_DIR}/config/local.conf}"

usage() {
    cat <<EOF
homelab-doctor ${VERSION}

用法：
  homelab-doctor [--config FILE] config validate
  homelab-doctor [--config FILE] doctor router
  homelab-doctor version

命令：
  config validate   校验配置，不连接任何设备
  doctor router     通过 SSH 流式执行 OpenWrt 只读探针
  version           显示版本
EOF
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --config)
            [ "$#" -ge 2 ] || { hd_fail '--config 缺少文件路径'; exit 2; }
            CONFIG_FILE="$2"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *) break ;;
    esac
done

COMMAND="${1:-}"
SUBCOMMAND="${2:-}"

case "${COMMAND}:${SUBCOMMAND}" in
    version:)
        printf '%s\n' "$VERSION"
        ;;
    config:validate)
        hd_load_config "$CONFIG_FILE" || exit 1
        if hd_validate_config; then
            hd_ok "配置合法：${CONFIG_FILE}"
        else
            exit 1
        fi
        ;;
    doctor:router)
        hd_load_config "$CONFIG_FILE" || exit 1
        hd_validate_config || exit 1

        hd_heading "连接 ${ROUTER_USER}@${ROUTER_HOST} 执行只读探针"
        ssh -o BatchMode=yes \
            -o "ConnectTimeout=${SSH_CONNECT_TIMEOUT}" \
            "${ROUTER_USER}@${ROUTER_HOST}" \
            "DNS_SERVER='${DNS_SERVER}' SPLIT_DOMAIN='${SPLIT_DOMAIN}' SPLIT_EXPECTED_IP='${SPLIT_EXPECTED_IP}' SERVICE_URL='${SERVICE_URL}' DIRECT_DOMAIN_SUFFIX='${DIRECT_DOMAIN_SUFFIX}' LAN_CIDR='${LAN_CIDR}' VPN_DNS='${VPN_DNS}' VPN_SUBNET='${VPN_SUBNET}' sh -s" \
            < "${ROOT_DIR}/probes/openwrt/network.sh"
        ;;
    *)
        usage >&2
        exit 2
        ;;
esac
