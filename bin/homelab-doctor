#!/bin/sh
set -u

SELF_DIR=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
ROOT_DIR=$(CDPATH='' cd -- "${SELF_DIR}/.." && pwd)

. "${ROOT_DIR}/lib/common.sh"
. "${ROOT_DIR}/lib/config.sh"
. "${ROOT_DIR}/lib/doctor.sh"

VERSION=$(sed -n '1p' "${ROOT_DIR}/VERSION" 2>/dev/null)
CONFIG_FILE="${HOMELAB_DOCTOR_CONFIG:-${ROOT_DIR}/config/local.conf}"

usage() {
    cat <<EOF
homelab-doctor ${VERSION}

用法：
  homelab-doctor [--config FILE] config validate
  homelab-doctor [--config FILE] doctor dns
  homelab-doctor [--config FILE] doctor mihomo
  homelab-doctor [--config FILE] doctor openvpn
  homelab-doctor [--config FILE] doctor firewall
  homelab-doctor [--config FILE] doctor router
  homelab-doctor version

命令：
  config validate   校验配置，不连接任何设备
  doctor dns        诊断 DNS 与 split-DNS
  doctor mihomo     诊断 OpenClash/Mihomo 运行态与规则
  doctor openvpn    诊断 OpenVPN DNS 下发与路由
  doctor firewall   诊断 fw3/iptables 或 fw4/nftables 规则
  doctor router     通过一次 SSH 聚合所有只读模块
  version           显示版本
EOF
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --config)
            [ "$#" -ge 2 ] || { hd_fail '--config 缺少文件路径'; exit 2; }
            CONFIG_FILE="$2"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *) break ;;
    esac
done

COMMAND="${1:-}"
SUBCOMMAND="${2:-}"

case "${COMMAND}:${SUBCOMMAND}" in
    version:)
        printf '%s\n' "$VERSION"
        ;;
    config:validate)
        hd_load_config "$CONFIG_FILE" || exit 2
        if hd_validate_config; then
            hd_ok "配置合法：${CONFIG_FILE}"
        else
            exit 2
        fi
        ;;
    doctor:dns|doctor:mihomo|doctor:openvpn|doctor:firewall|doctor:router)
        hd_load_config "$CONFIG_FILE" || exit 2
        hd_validate_config "$SUBCOMMAND" || exit 2
        hd_doctor_remote "$SUBCOMMAND"
        exit $?
        ;;
    *)
        usage >&2
        exit 2
        ;;
esac
